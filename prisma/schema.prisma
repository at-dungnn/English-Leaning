// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===== Phase 1: Auth =====

enum Role {
  USER
  ADMIN
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String? // null for social-only accounts
  role           Role      @default(USER)

  accounts  Account[]
  sessions  Session[]
  decks     Deck[]
  reviews   Review[]
  materials Material[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// OAuth accounts linked to a user (Google, Facebook, ...) — Auth.js adapter shape.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Only used if we ever switch to database sessions; kept for adapter compatibility.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ===== Phase 2: Flashcard learning + SRS =====

model Deck {
  id          String   @id @default(cuid())
  title       String
  description String?
  isPublic    Boolean  @default(false)
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  cards       Card[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
}

model Card {
  id       String  @id @default(cuid())
  deckId   String
  deck     Deck    @relation(fields: [deckId], references: [id], onDelete: Cascade)
  term     String // English word/phrase
  ipa      String? // phonetic transcription
  meaning  String // Vietnamese meaning
  example  String? // example sentence
  imageUrl String?
  reviews  Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deckId])
}

// Per-user SM-2 spaced-repetition state for a card.
model Review {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId         String
  card           Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  ease           Float     @default(2.5) // ease factor (min 1.3)
  interval       Int       @default(0) // days until next review
  repetitions    Int       @default(0) // consecutive correct answers
  dueAt          DateTime  @default(now())
  lastReviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, cardId])
  @@index([userId, dueAt])
}

// ===== Phase 4: Learning materials =====

enum MaterialType {
  READING
  GRAMMAR
  VOCABULARY
  LISTENING
  TOEIC
  IELTS
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Material {
  id          String       @id @default(cuid())
  title       String
  summary     String?
  body        String // long-form content (plain text / markdown)
  type        MaterialType
  level       Level
  tags        String[]
  isPublished Boolean      @default(false)
  authorId    String?
  author      User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, level])
  @@index([isPublished])
}
